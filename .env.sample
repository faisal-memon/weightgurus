# Sample environment file for Weight Gurus
# Copy this file to .env and replace the placeholder values with your actual credentials.

WG_USERNAME=your_username_here
WG_PASSWORD=your_password_here
WG_HOST_OUTPUT_DIR=/path/on/host
WG_CSV_FILE=/output/weights.csv
WG_UPDATE_INTERVAL=24h
WG_JITTER_SECONDS_MAX=300
